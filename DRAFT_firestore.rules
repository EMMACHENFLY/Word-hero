rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Game Sets
    match /gameSets/{setId} {
      allow read: if true; // Publicly shared
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }

    // Game Results
    match /gameResults/{resultId} {
      allow read: if request.auth != null; // Teachers check results
      allow create: if true; // Students can submit results without login (per user query "share link")
      allow update, delete: if false; // Results are immutable once sent
    }
  }
}
